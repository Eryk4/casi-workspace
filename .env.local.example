# Skopiuj ten plik jako .env.local i uzupelnij dane swojej skrzynki.
# Dla Google Workspace / Gmail najczesciej sprawdzi sie taki zestaw:

# Opcjonalne oznaczenie wersji widoczne w /api/meta i UI.
# Najwygodniej ustawic automatycznie: python sync_release_id.py
INVOICE_APP_RELEASE_ID=

INVOICE_EMAIL_IMAP_HOST=imap.gmail.com
INVOICE_EMAIL_IMAP_PORT=993
INVOICE_EMAIL_IMAP_USERNAME=twoja_skrzynka@twojadomena.pl
INVOICE_EMAIL_IMAP_PASSWORD=twoje_haslo_aplikacji_google
INVOICE_EMAIL_IMAP_FOLDER=INBOX
INVOICE_EMAIL_IMAP_USE_SSL=1
INVOICE_EMAIL_FETCH_LIMIT=100
INVOICE_EMAIL_AUTOCHECK_ENABLED=0
INVOICE_EMAIL_AUTOCHECK_SECONDS=300

# Google Workspace OAuth dla centralnej skrzynki
# Publiczny adres jest potrzebny do callbacku, wiec lokalnie zwykle bedzie to Railway albo tunel HTTPS.
INVOICE_PUBLIC_BASE_URL=
INVOICE_EMAIL_GOOGLE_CLIENT_ID=
INVOICE_EMAIL_GOOGLE_CLIENT_SECRET=

# Slack webhook do importu dokumentow
INVOICE_SLACK_BOT_TOKEN=
INVOICE_SLACK_SIGNING_SECRET=

# Przypomnienia Telegram
INVOICE_ENABLE_TELEGRAM_TASK_REMINDERS=1
INVOICE_TASK_REMINDER_POLL_SECONDS=60
INVOICE_TASK_REMINDER_WORKER_POLL_SECONDS=15
INVOICE_TASK_REMINDER_RETRY_MINUTES=15
INVOICE_TASK_REMINDER_PROCESSING_TIMEOUT_MINUTES=10
INVOICE_TASK_REMINDER_MAX_ATTEMPTS=5
